# Polymarket HFT Bot — Environment Variables
# Copy this file to .env and fill in your keys.

# ---------------------------------------------------------------------------
# Polymarket CLOB Client (required for live_farmer.py and live_execution.py)
# ---------------------------------------------------------------------------

# Polygon wallet private key (hex, with or without 0x prefix)
POLY_PK=your_polygon_private_key_here

# CLOB API host (default: https://clob.polymarket.com)
POLY_HOST=https://clob.polymarket.com

# Polygon chain ID (137 = mainnet, 80002 = Amoy testnet)
CHAIN_ID=137

# API credentials (run with just POLY_PK first to auto-derive these)
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Polymarket proxy/Safe wallet address (where your deposited funds live).
# Auto-discovered from trade history if not set, but setting it avoids the lookup.
# Find it: make one trade on polymarket.com, then check the bot logs for the address.
POLY_FUNDER=

# ---------------------------------------------------------------------------
# Polygon RPC (optional, defaults to https://polygon-rpc.com)
# ---------------------------------------------------------------------------
# For lower latency, use a dedicated RPC from Alchemy or QuickNode:
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-rpc.com

# ---------------------------------------------------------------------------
# Coinglass (required for cross-venue liquidation monitoring in Phase 1)
# ---------------------------------------------------------------------------
COINGLASS_API_KEY=your_coinglass_api_key_here
